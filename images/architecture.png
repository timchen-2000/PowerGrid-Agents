<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="600" viewBox="0 0 1200 600">
  <!-- 背景和标题 -->
  <rect width="1200" height="600" fill="white"/>
  <text x="600" y="40" font-family="Arial, sans-serif" font-size="24" font-weight="bold" text-anchor="middle">电力设备监控智能问答系统技术架构图</text>
  
  <!-- 数据输入与处理层 -->
  <rect x="20" y="60" width="280" height="480" fill="#E6E6FA" stroke="#663399" stroke-width="2"/>
  <text x="160" y="90" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">数据输入与处理层</text>
  
  <!-- PDF文档 -->
  <rect x="40" y="120" width="240" height="60" fill="#FFFFFF" stroke="#663399" stroke-width="1"/>
  <text x="160" y="145" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">PDF文档（变电设备监控信</text>
  <text x="160" y="165" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">息释义及处置原则.pdf）</text>
  
  <!-- PyPDFLoader -->
  <rect x="40" y="200" width="240" height="40" fill="#FFFFFF" stroke="#663399" stroke-width="1"/>
  <text x="160" y="225" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">PyPDFLoader加载PDF</text>
  
  <!-- 文档分割 -->
  <rect x="40" y="260" width="240" height="80" fill="#FFFFFF" stroke="#663399" stroke-width="1"/>
  <text x="160" y="285" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">RecursiveCharacterTextSplitter</text>
  <text x="160" y="305" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">文档分割</text>
  <text x="160" y="325" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">(chunk_size=500, chunk_overlap=100)</text>
  
  <!-- 核心处理层 -->
  <rect x="320" y="60" width="520" height="480" fill="#FFE4E1" stroke="#FF69B4" stroke-width="2"/>
  <text x="580" y="90" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">核心处理层</text>
  
  <!-- 千问Embedding模型 -->
  <rect x="360" y="120" width="240" height="60" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="480" y="145" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">千问Embedding模型 (text-</text>
  <text x="480" y="165" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">embedding-v4) → 1536维向量</text>
  
  <!-- FAISS向量数据库 -->
  <rect x="360" y="200" width="240" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="480" y="225" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">FAISS向量数据库存储</text>
  
  <!-- BM25关键词检索器 -->
  <rect x="620" y="140" width="200" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="720" y="165" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">BM25关键词检索器</text>
  
  <!-- 混合检索模块 -->
  <rect x="480" y="260" width="240" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="600" y="285" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">混合检索模块（BM25 + FAISS）</text>
  
  <!-- BGE重排模型 -->
  <rect x="480" y="320" width="240" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="600" y="345" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">BGE重排模型</text>
  <text x="600" y="365" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">(BAAI/bge-small-zh-v1.5)</text>
  
  <!-- 上下文构建 -->
  <rect x="480" y="400" width="240" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="600" y="425" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">上下文构建</text>
  
  <!-- DeepSeek大模型 -->
  <rect x="480" y="460" width="240" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="600" y="485" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">DeepSeek大模型</text>
  <text x="600" y="505" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">(deepseek-chat)</text>
  
  <!-- 对话历史管理 -->
  <rect x="360" y="460" width="100" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="410" y="485" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">对话历史管理</text>
  <text x="410" y="505" font-family="Arial, sans-serif" font-size="8" text-anchor="middle">(保留最近10轮)</text>
  
  <!-- 回答处理 -->
  <rect x="480" y="520" width="240" height="40" fill="#FFFFFF" stroke="#FF69B4" stroke-width="1"/>
  <text x="600" y="545" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">回答处理</text>
  
  <!-- 部署与交互层 -->
  <rect x="860" y="60" width="320" height="480" fill="#E8F5E8" stroke="#228B22" stroke-width="2"/>
  <text x="1020" y="90" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">部署与交互层</text>
  
  <!-- FastAPI后端服务 -->
  <rect x="880" y="120" width="280" height="60" fill="#FFFFFF" stroke="#228B22" stroke-width="1"/>
  <text x="1020" y="145" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">FastAPI后端服务</text>
  <text x="1020" y="165" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">(8000端口)</text>
  
  <!-- .env配置文件 -->
  <rect x="880" y="200" width="280" height="60" fill="#FFFFFF" stroke="#228B22" stroke-width="1"/>
  <text x="1020" y="225" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">.env配置文件</text>
  <text x="1020" y="145" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">(DASHSCOPE_API_KEY)</text>
  
  <!-- 前端界面 -->
  <rect x="880" y="280" width="280" height="80" fill="#FFFFFF" stroke="#228B22" stroke-width="1"/>
  <text x="1020" y="310" font-family="Arial, sans-serif" font-size="12" text-anchor="middle">前端界面</text>
  <text x="1020" y="330" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">(HTML/CSS/JavaScript +</text>
  <text x="1020" y="350" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">marked.js)</text>
  
  <!-- 箭头和连接线 -->
  <!-- PDF → PyPDFLoader -->
  <line x1="160" y1="180" x2="160" y2="200" stroke="#333" stroke-width="2"/>
  <polygon points="160,200 155,190 165,190" fill="#333"/>
  
  <!-- PyPDFLoader → 文档分割 -->
  <line x1="160" y1="240" x2="160" y2="260" stroke="#333" stroke-width="2"/>
  <polygon points="160,260 155,250 165,250" fill="#333"/>
  
  <!-- 文档分割 → 千问Embedding -->
  <line x1="260" y1="300" x2="360" y2="150" stroke="#333" stroke-width="2"/>
  <polygon points="360,150 350,145 350,155" fill="#333"/>
  
  <!-- 千问Embedding → FAISS -->
  <line x1="480" y1="180" x2="480" y2="200" stroke="#333" stroke-width="2"/>
  <polygon points="480,200 475,190 485,190" fill="#333"/>
  
  <!-- FAISS → 混合检索 -->
  <line x1="480" y1="240" x2="480" y2="260" stroke="#333" stroke-width="2"/>
  <polygon points="480,260 475,250 485,250" fill="#333"/>
  
  <!-- BM25 → 混合检索 -->
  <line x1="720" y1="180" x2="600" y2="260" stroke="#333" stroke-width="2"/>
  <polygon points="600,260 590,255 590,265" fill="#333"/>
  
  <!-- 混合检索 → BGE重排 -->
  <line x1="600" y1="300" x2="600" y2="320" stroke="#333" stroke-width="2"/>
  <polygon points="600,320 595,310 605,310" fill="#333"/>
  <text x="650" y="310" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">召回Top 8文档</text>
  
  <!-- BGE重排 → 上下文构建 -->
  <line x1="600" y1="360" x2="600" y2="400" stroke="#333" stroke-width="2"/>
  <polygon points="600,400 595,390 605,390" fill="#333"/>
  <text x="650" y="380" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">重排后返回Top 3文档</text>
  
  <!-- 上下文构建 → DeepSeek -->
  <line x1="600" y1="440" x2="600" y2="460" stroke="#333" stroke-width="2"/>
  <polygon points="600,460 595,450 605,450" fill="#333"/>
  
  <!-- DeepSeek → 回答处理 -->
  <line x1="600" y1="500" x2="600" y2="520" stroke="#333" stroke-width="2"/>
  <polygon points="600,520 595,510 605,510" fill="#333"/>
  
  <!-- 对话历史管理 ↔ DeepSeek -->
  <line x1="460" y1="480" x2="480" y2="480" stroke="#333" stroke-width="2"/>
  <polygon points="480,480 470,475 470,485" fill="#333"/>
  <line x1="480" y1="490" x2="460" y2="490" stroke="#333" stroke-width="2"/>
  <polygon points="460,490 470,485 470,495" fill="#333"/>
  
  <!-- 回答处理 → FastAPI -->
  <line x1="720" y1="540" x2="880" y2="150" stroke="#333" stroke-width="2"/>
  <polygon points="880,150 870,145 870,155" fill="#333"/>
  <text x="780" y="340" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">HTTP POST请求</text>
  
  <!-- FastAPI → 前端界面 -->
  <line x1="1020" y1="180" x2="1020" y2="280" stroke="#333" stroke-width="2"/>
  <polygon points="1020,280 1015,270 1025,270" fill="#333"/>
  
  <!-- 前端界面 → FastAPI -->
  <line x1="1020" y1="360" x2="1020" y2="240" stroke="#333" stroke-width="2"/>
  <polygon points="1020,240 1015,250 1025,250" fill="#333"/>
  <text x="1070" y="300" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">HTTP POST请求</text>
  
  <!-- .env → FastAPI -->
  <line x1="1020" y1="260" x2="1020" y2="180" stroke="#333" stroke-width="2"/>
  <polygon points="1020,180 1015,190 1025,190" fill="#333"/>
  
  <!-- 用户查询 → BM25 -->
  <line x1="720" y1="120" x2="720" y2="140" stroke="#333" stroke-width="2"/>
  <polygon points="720,140 715,130 725,130" fill="#333"/>
  <text x="770" y="130" font-family="Arial, sans-serif" font-size="10" text-anchor="middle">用户查询</text>
  
  <!-- 用户查询 → FastAPI -->
  <line x1="720" y1="120" x2="880" y2="150" stroke="#333" stroke-width="2"/>
  <polygon points="880,150 870,145 870,155" fill="#333"/>
</svg>